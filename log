# FACTOR ANALYSIS
# =====================================

# Libraries
install.packages("psych")    # run once
install.packages("corrplot") # run once
library(psych)
library(corrplot)

# Load data
df <- read.csv("C:/Users/hp/Desktop/MA datasets/airplane.csv")

# Keep only numeric columns
df_num <- df[, sapply(df, is.numeric)]

# Remove NA
df_num <- na.omit(df_num)

# Correlation matrix
cor_mat <- cor(df_num, use = "complete.obs")

# -------------------------------
# PLOTS (FACTOR ANALYSIS)
# -------------------------------

# 1. Correlation plot
corrplot(cor_mat)

# 2. Scree plot (IMPORTANT)
fa.parallel(df_num, fa = "fa")

# 3. Factor Analysis
fa_model <- fa(cor_mat, nfactors = 4, rotate = "promax")

# Print result
print(fa_model)

# 4. Factor diagram (VERY IMPORTANT)
fa.diagram(fa_model)


