# =====================================
# LOGISTIC REGRESSION
# =====================================

# Load data
train <- read.csv("C:/Users/hp/Desktop/MA datasets/airplane.csv")
test  <- read.csv("C:/Users/hp/Desktop/MA datasets/ap_test.csv")

# Remove missing values
train <- na.omit(train)
test  <- na.omit(test)

# Convert target to factor
train$satisfaction <- factor(train$satisfaction)
test$satisfaction  <- factor(test$satisfaction)

# Train model
model <- glm(satisfaction ~ ., data = train, family = binomial)

# Predict probabilities
prob <- predict(model, test, type = "response")

# Convert to class
pred <- ifelse(prob > 0.5, "satisfied", "neutral")

# Accuracy
mean(pred == test$satisfaction)

# Confusion Matrix
table(pred, test$satisfaction)

# -------------------------------
# PLOTS (LOGISTIC)
# -------------------------------

# 1. ROC Curve
install.packages("pROC")   # run once
library(pROC)

actual <- as.numeric(test$satisfaction) - 1
roc_obj <- roc(actual, prob)
plot(roc_obj, main = "ROC Curve")

# 2. Histogram of probabilities
hist(prob, main = "Predicted Probabilities", xlab = "Probability")

# 3. Model diagnostic plots
par(mfrow = c(2,2))
plot(model)



