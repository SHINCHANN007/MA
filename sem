# load packages
library(lavaan)
library(semPlot)
library(dplyr)

# load dataset
data <- read.csv("C:/Users/anura/Desktop/apple_quality.csv")

# Remove ID column 
data$A_id <- NULL

# convert Quality to Numeric 
data$Quality <- as.numeric(as.factor(data$Quality))

# Convert Acidity to numeric (IMPORTANT FIX)
data$Acidity <- as.numeric(data$Acidity)

# Path SEM model
model <- '
# relationships
Sweetness ~ Size
Juiciness ~ Size + Crunchiness
Acidity ~ Size 
Quality ~ Size + Sweetness + Juiciness + Acidity

# covariance
Size ~~ Crunchiness
'

# Fit model
fit <- sem(model, data = data)

# Summary
summary(fit, standardized = TRUE, fit.measures = TRUE)

# PLOT
semPaths(fit,
         what="std",
         layout="tree",
         style="ram",
         edge.label.cex=1.2,
         sizeMan=7,
         residuals=FALSE,
         intercepts=FALSE,
         nCharNodes=0,
         posCol="darkgreen",
         negCol="red",
         edge.width=2,
         weighted=TRUE,
         fade=FALSE,
         rotation=2)
